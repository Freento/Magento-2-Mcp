<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">freento_mcp_aclrole_listing.freento_mcp_aclrole_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Role</label>
            </button>
        </buttons>
        <spinner>freento_mcp_aclrole_columns</spinner>
        <deps>
            <dep>freento_mcp_aclrole_listing.freento_mcp_aclrole_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="freento_mcp_aclrole_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">role_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Freento_Mcp::acl_rules</aclResource>
        <dataProvider class="Freento\Mcp\Ui\DataProvider\AclRoleListingDataProvider" name="freento_mcp_aclrole_listing_data_source">
            <settings>
                <requestFieldName>role_id</requestFieldName>
                <primaryFieldName>role_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="freento_mcp_aclrole_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>role_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="role_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Role Name</label>
            </settings>
        </column>
        <column name="access_type" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Access Type</label>
                <options>
                    <option name="all" xsi:type="array">
                        <item name="value" xsi:type="string">all</item>
                        <item name="label" xsi:type="string" translate="true">All Tools</item>
                    </option>
                    <option name="specified" xsi:type="array">
                        <item name="value" xsi:type="string">specified</item>
                        <item name="label" xsi:type="string" translate="true">Specified</item>
                    </option>
                </options>
            </settings>
        </column>
        <column name="tools_count">
            <settings>
                <label translate="true">Tools Count</label>
                <sortable>false</sortable>
                <filter>false</filter>
            </settings>
        </column>
        <column name="users_count">
            <settings>
                <label translate="true">Users Count</label>
                <sortable>false</sortable>
                <filter>false</filter>
            </settings>
        </column>
        <actionsColumn name="actions" class="Freento\Mcp\Ui\Component\Listing\Column\AclRoleActions">
            <settings>
                <indexField>role_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
